    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [56, 76.0]
    rotation: 0
    state: enabled

blocks:
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: '9600'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [392, 72.0]
    rotation: 0
    state: enabled
- name: samp_rate_base
  id: variable
  parameters:
    comment: ''
    value: sps*samp_rate
