options:
  parameters:
    author: OpenAI Codex
    catch_exceptions: 'True'
    category: '[Learning Demo]'
    cmake_opt: ''
    comment: "\u81EA\u5305\u542B\u7684 PlutoSDR 2-FSK \u6587\u672C\u63A5\u6536\u5B66\
      \u4E60\u6D41\u56FE"
    copyright: '2026'
    description: "\u81EA\u52A8\u627E\u5305\u5E76\u5C06 el psy kongroo \u5199\u5165\
      \u6587\u672C\u6587\u4EF6\uFF1B\u65E0\u5916\u90E8 Python \u6587\u4EF6\u4F9D\u8D56"
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: no_gui
    hier_block_src_path: '.:'
    id: simple_fsk_rx_pluto
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Simple 2-FSK Text RX with PlutoSDR
    window_size: (1360,840)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

