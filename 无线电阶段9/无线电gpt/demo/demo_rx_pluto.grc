options:
  parameters:
    author: OpenAI Codex / wireless demo
    catch_exceptions: 'True'
    category: '[Demo]'
    cmake_opt: ''
    comment: "PlutoSDR DSSS \u6D4B\u8BD5\u63A5\u6536\u7AEF\uFF1B\u6210\u529F\u540E\
      \u5199 decoded_message.txt\u3002"
    copyright: '2026'
    description: "PlutoSDR -> \u7A81\u53D1\u540C\u6B65/CFO -> DSSS \u89E3\u6269 ->\
      \ \u53BB\u4EA4\u7EC7/\u7EF4\u7279\u6BD4 -> \u89E3\u6270/CRC"
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: demo_rx_pluto
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Demo RX - DSSS protected text over PlutoSDR
    window_size: (1350,820)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: capture_samples
  id: variable
  parameters:
    comment: "\u6709\u9650\u91C7\u96C6\uFF0C\u65F6\u95F4\u5230\u540E\u81EA\u52A8\u9000\
      \u51FA"
    value: int(capture_seconds*samp_rate)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [824, 112]
    rotation: 0
    state: enabled
