options:
  parameters:
    author: Competition Team
    catch_exceptions: 'True'
    category: '[SDR Contest]'
    cmake_opt: ''
    comment: "\u72EC\u7ACB\u63A5\u6536\u7AEF\u3002\u4E0D\u542B\u4EFF\u771F\u4FE1\u9053\
      \uFF1B\u4FDD\u7559\u5B8C\u6574\u534F\u8BAE\u89E3\u7801\u3001\u539F\u59CB IQ\
      \ \u548C\u6307\u6807\u8F93\u51FA\u3002"
    copyright: '2026'
    description: "\u539F\u751F PlutoSDR Source -> \u6709\u9650 IQ \u91C7\u96C6 ->\
      \ \u540C\u6B65/FEC/CRC/\u53BB\u91CD\u91CD\u7EC4 + IQ \u6587\u4EF6"
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: no_gui
    hier_block_src_path: '.:'
    id: sdr_contest_rx_pluto
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: SDR Contest PlutoSDR Receiver
    window_size: (1450,900)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: capture_samples
  id: variable
  parameters:
    comment: "\u672C\u6B21\u5B9E\u9645\u8BF7\u6C42\u6837\u672C\u6570"
    value: min(int(rf_duration_s*samp_rate), max_capture_samples)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1456, 40.0]
    rotation: 0
    state: enabled
