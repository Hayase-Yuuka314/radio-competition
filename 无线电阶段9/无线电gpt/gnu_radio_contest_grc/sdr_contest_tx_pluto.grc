options:
  parameters:
    author: Competition Team
    catch_exceptions: 'True'
    category: '[SDR Contest]'
    cmake_opt: ''
    comment: "\u72EC\u7ACB\u53D1\u5C04\u7AEF\u3002\u9ED8\u8BA4\u5360\u4F4D\u6E90\u4E14\
      \ RF \u95E8\u5173\u95ED\uFF1B\u4E0D\u542B\u4EFF\u771F\u4FE1\u9053\u3002"
    copyright: '2026'
    description: "\u5360\u4F4D\u4FE1\u53F7/\u7ADE\u8D5B\u6587\u4EF6\u63A5\u53E3 ->\
      \ \u6709\u9650\u6837\u672C\u4E0E\u6388\u6743\u95E8 -> \u539F\u751F PlutoSDR\
      \ Sink"
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: no_gui
    hier_block_src_path: '.:'
    id: sdr_contest_tx_pluto
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: SDR Contest PlutoSDR Transmitter
    window_size: (1450,900)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

