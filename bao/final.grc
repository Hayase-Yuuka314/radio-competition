options:
  parameters:
    author: OpenAI Codex
    catch_exceptions: 'True'
    category: '[Learning Demo]'
    cmake_opt: ''
    comment: "\u81EA\u5305\u542B\u7684 PlutoSDR 2-FSK \u6587\u672C\u53D1\u5C04\u5B66\
      \u4E60\u6D41\u56FE"
    copyright: '2026'
    description: "\u53CD\u590D\u53D1\u9001 el psy kongroo\uFF1B\u65E0\u5916\u90E8\
      \ Python \u6587\u4EF6\u4F9D\u8D56"
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: simple_fsk_tx_pluto
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Simple 2-FSK Text TX with PlutoSDR
    window_size: (1320,760)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

